# EVVM x402 (Tempo Moderato, chain 42431)
RECEIVER_ACCOUNT=
EVVM_CORE_ADDRESS=
# Facilitator: must be 0x + 64 hex chars, no quotes (e.g. MetaMask export)
EXECUTOR_PRIVATE_KEY=
# CCP / principal token (TIP-20) on Tempo — set from your EVVM deployment or explorer
PRINCIPAL_TOKEN_ADDRESS=
# Optional: defaults to https://rpc.moderato.tempo.xyz
# RPC_URL=
# Optional: defaults to 1154 (ClinicalClaw)
# EVVM_ID=1154

# MPP + purl (pathUSD on Moderato by default)
MPP_SECRET_KEY=
# Optional: defaults to pathUSD testnet address
# MPP_TEMPO_CURRENCY=0x20c0000000000000000000000000000000000000
# Optional: defaults to RECEIVER_ACCOUNT
# MPP_TEMPO_RECIPIENT=
